{
"name": "simple-chat-app",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "durable_objects": {
    "bindings": [
      {
        "name": "CHAT_ROOM",
        "class_name": "ChatRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ChatRoom"]
    }
  ],
  "r2_buckets": [
    {
      "binding": "CHAT_FILES",
      "bucket_name": "chat-files"
    }
  ],
  "triggers": {
    "crons": ["0 */6 * * *"]
  }
}
